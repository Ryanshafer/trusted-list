---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ProfilePage } from "../features/profile/components/ProfilePage";
import currentUser from "../../data/current-user.json";
import type { ProfileData, ViewerData } from "../features/profile/types";

const profile = currentUser as unknown as ProfileData;

const viewerData: ViewerData = {
  userId: profile.id,
  name: profile.name,
  firstName: profile.firstName,
  avatarUrl: profile.avatarUrl,
  role: `${profile.title} · ${profile.company}`,
};
---

<BaseLayout
  title={`${profile.name} — The Trusted List`}
  description={`Profile for ${profile.name}`}
  bodyClass="bg-background"
  showHeader={false}
  showFooter={false}
>
  <ProfilePage
    profile={profile}
    viewerData={viewerData}
    isOwner={true}
    connectionDegree={null}
    availableSkills={profile.verifiedSkills}
    basePath="/trusted-list"
    client:load
    slot="main"
  />
</BaseLayout>
