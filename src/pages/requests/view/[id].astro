---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import RequestDetailPage from "../../../features/requests/RequestDetailPage";
import requestsData from "../../../../data/requests.json";
import interactionsData from "../../../../data/interactions.json";
import profilesData from "../../../../data/profiles.json";
import currentUser from "../../../../data/current-user.json";
import type { CardData } from "../../../features/dashboard/types";
import type { InteractionCard } from "../../../features/interactions/utils/data";
import type { OpenRequest, ProfileData } from "../../../features/profile/types";

type InteractionsPayload = {
  helped: InteractionCard[];
  inProgress: InteractionCard[];
};

type ProfileWithOpenRequests = ProfileData & {
  openRequests?: OpenRequest[];
};

export function getStaticPaths() {
  const requestCards = requestsData as CardData[];
  const interactions = interactionsData as InteractionsPayload;
  const profiles = profilesData as ProfileWithOpenRequests[];
  const currentUserProfile = currentUser as ProfileWithOpenRequests;

  const reqIds = requestCards.map((request) => request.id);
  const helpedIds = interactions.helped.map((request) => request.id);
  const inProgressIds = interactions.inProgress.map((request) => request.id);
  const profileOpenRequestIds = [currentUserProfile, ...profiles].flatMap(
    (profile) => (profile.openRequests ?? []).map((request) => request.requestId)
  );

  const allIds = [
    ...new Set([
      ...reqIds,
      ...helpedIds,
      ...inProgressIds,
      ...profileOpenRequestIds,
    ]),
  ];

  return allIds.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
---

<BaseLayout
  title={`Request Detail`}
  description="View a help request on The Trusted List."
  bodyClass="bg-background"
  showHeader={false}
  showFooter={false}
>
  <RequestDetailPage id={id ?? ""} client:load slot="main" />
</BaseLayout>
